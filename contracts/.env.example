# Copy to contracts/.env and fill in. NEVER commit the real .env.

# Deployer private key (use a throwaway funded with Sepolia ETH)
PRIVATE_KEY=

# Sepolia RPC endpoint (Alchemy / Infura / public)
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=

# Nox network / gateway configuration (from nox-hardhat-starter — confirm exact keys)
NOX_GATEWAY_URL=
NOX_API_KEY=
